{
  "functions": {
    "api/**/*": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/status", "destination": "/index.html" },
    { "source": "/dsbuddy", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
